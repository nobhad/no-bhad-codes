<%# Table Pagination - Page controls %>
<%# Locals: tableDef, totalRows %>

<div class="table-pagination" data-action="pagination">
  <div class="pagination-info">
    <span class="pagination-showing">Showing 1-<%= Math.min(tableDef.pageSize || 25, totalRows) %> of <%= totalRows %></span>
  </div>
  <div class="pagination-controls">
    <button type="button" class="btn-icon pagination-btn" data-page="prev" disabled aria-label="Previous page">
      <svg class="lucide-icon" width="16" height="16"><use href="#icon-chevron-left"></use></svg>
    </button>
    <span class="pagination-current" data-page-info>Page 1</span>
    <button type="button" class="btn-icon pagination-btn" data-page="next" aria-label="Next page"
      <% if (totalRows <= (tableDef.pageSize || 25)) { %>disabled<% } %>
    >
      <svg class="lucide-icon" width="16" height="16"><use href="#icon-chevron-right"></use></svg>
    </button>
  </div>
</div>
