<%# Status Cell %>
<%# Locals: value, col, row %>
<%
var statusConfig = col.statusConfig;
var label = value || '—';
var variant = 'pending';
if (statusConfig && statusConfig.options) {
  var opt = statusConfig.options.find(function(o) { return o.value === value; });
  if (opt) {
    label = opt.label;
    variant = opt.variant;
  }
}
%>
<span class="status-badge status-badge--<%= variant %>"><%= label %></span>