<!-- Auth Gate - React Mount Point -->
<div
  class="auth-gate"
  id="auth-gate"
  data-portal-type="<%= portalType === 'admin' ? 'admin' : 'client' %>"
  data-business-name="<%= typeof businessName !== 'undefined' ? businessName : '' %>"
  data-auth-title="<%= config.authTitle %>"
  data-auth-description="<%= config.authDescription %>"
></div>

<%- viteEntryCss('/src/react/features/auth/mount-auth-gate.tsx') %>
<script type="module">
  import { autoMountAuthGate } from '<%- viteAsset('/src/react/features/auth/mount-auth-gate.tsx') %>';

  document.addEventListener('DOMContentLoaded', function () {
    autoMountAuthGate();
  });
</script>
