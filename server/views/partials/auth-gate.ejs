<!-- Auth Gate - Login Form -->
<div class="auth-gate" id="auth-gate">
  <div class="auth-gate-container">
    <div class="auth-gate-header">
      <img src="/images/avatar.svg" alt="No Bhad Codes" class="auth-gate-logo" />
      <h1><%= config.authTitle %></h1>
      <p><%= config.authDescription %></p>
    </div>
    <% if (portalType === 'admin') { %>
      <!-- Admin Login Form -->
      <form class="auth-gate-form" id="admin-login-form" method="post" action="/api/auth/admin/login" autocomplete="off" novalidate>
        <!-- Hidden username field for accessibility and password managers -->
        <input
          type="email"
          id="admin-username"
          name="username"
          value="admin@nobhad.codes"
          autocomplete="username"
          tabindex="-1"
          aria-hidden="true"
          style="position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0, 0, 0, 0); border: 0;"
        />
        <div class="form-group">
          <label for="admin-password" class="sr-only">Admin Password</label>
          <div class="password-input-wrapper">
            <input
              type="password"
              id="admin-password"
              name="password"
              placeholder="Admin Password"
              required
              autocomplete="current-password"
            />
            <button type="button" class="password-toggle" id="password-toggle" aria-label="Toggle password visibility">
              <svg class="eye-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                <circle cx="12" cy="12" r="3"></circle>
              </svg>
            </button>
          </div>
        </div>
        <div class="auth-error" id="auth-error"></div>
        <button type="submit" class="btn btn-auth auth-submit">
          <span class="btn-text">Sign In</span>
          <span class="btn-loading" style="display: none;">Signing in...</span>
        </button>
      </form>
      <script>
        // Toggle auth button state based on input
        document.addEventListener('DOMContentLoaded', function() {
          const passwordInput = document.getElementById('admin-password');
          const submitBtn = document.querySelector('.auth-submit');
          if (passwordInput && submitBtn) {
            passwordInput.addEventListener('input', function() {
              if (this.value.trim().length > 0) {
                submitBtn.classList.add('active');
              } else {
                submitBtn.classList.remove('active');
              }
            });
          }
        });
      </script>
    <% } else { %>
      <!-- Client Portal Login Form -->
      <form class="auth-gate-form" id="portal-login-form" method="post" action="/api/auth/portal-login" novalidate>
        <div class="form-group">
          <label for="portal-email" class="sr-only">Email Address</label>
          <input
            type="email"
            id="portal-email"
            name="email"
            class="form-input"
            placeholder="Email Address"
            required
            autocomplete="username"
          />
          <span id="email-error" class="error-message" style="display: none;"></span>
        </div>
        <div class="form-group">
          <label for="portal-password" class="sr-only">Password</label>
          <div class="password-input-wrapper">
            <input
              type="password"
              id="portal-password"
              name="password"
              class="form-input"
              placeholder="Password"
              required
              autocomplete="current-password"
            />
            <button type="button" class="password-toggle" id="portal-password-toggle" data-password-toggle="portal-password" aria-label="Toggle password visibility">
              <svg class="eye-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                <circle cx="12" cy="12" r="3"></circle>
              </svg>
            </button>
          </div>
          <span id="password-error" class="error-message" style="display: none;"></span>
        </div>
        <div class="auth-error" id="auth-error"></div>
        <button type="submit" id="login-btn" class="btn btn-auth auth-submit">
          <span class="btn-text">Sign In</span>
          <span class="btn-loading" style="display: none;">Signing in...</span>
        </button>
      </form>
      <!-- Magic Link Form (hidden by default) -->
      <form class="auth-gate-form" id="magic-link-form" novalidate style="display: none;">
        <div class="form-group">
          <label for="magic-link-email" class="sr-only">Email Address</label>
          <input
            type="email"
            id="magic-link-email"
            name="email"
            class="form-input"
            placeholder="Email Address"
            required
            autocomplete="username"
          />
          <span id="magic-email-error" class="error-message" style="display: none;"></span>
        </div>
        <div class="auth-error" id="magic-link-error"></div>
        <div class="magic-link-success" id="magic-link-success" style="display: none;">
          <p>A secure login link has been sent to your email.</p>
          <p class="magic-link-info">Check your inbox and click the link to sign in.</p>
        </div>
        <button type="submit" id="magic-link-btn" class="btn btn-auth auth-submit">
          <span class="btn-text">Send Magic Link</span>
          <span class="btn-loading" style="display: none;">Sending...</span>
        </button>
      </form>
      <div class="auth-gate-footer">
        <a href="/client/forgot-password.html" id="forgot-password-link" class="auth-link">Forgot password?</a>
        <span class="auth-divider">|</span>
        <a href="#" id="magic-link-toggle" class="auth-link">Use magic link instead</a>
      </div>
    <% } %>
  </div>
</div>
