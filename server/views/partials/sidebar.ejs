<!-- Sidebar - Navigation only (branding/toggle now in unified header) -->
<aside class="sidebar" id="sidebar" role="navigation" aria-label="Portal navigation">
  <div class="sidebar-content">
    <!-- Navigation Buttons -->
    <div class="sidebar-buttons">
      <% config.navigation.forEach(item => { %>
        <button class="nav-btn<%= item.active ? ' active' : '' %>" id="btn-<%= item.id %>" data-tab="<%= item.dataTab || item.id %>"<% if (item.shortcut) { %> data-shortcut="<%= item.shortcut %>"<% } %> aria-label="<%= item.ariaLabel || item.label %>">
          <%- item.icon.replace('<svg ', '<svg class="nav-icon" aria-hidden="true" ') %>
          <span class="nav-label"><%= item.label %></span>
          <% if (item.badge) { %>
            <span class="sidebar-badge" id="<%= item.badge %>" aria-label="<%= item.label.toLowerCase() %> count"></span>
          <% } %>
        </button>
      <% }) %>
    </div>

    <!-- Sign Out Button -->
    <div class="sidebar-footer">
      <button type="button" class="nav-btn btn-logout" id="btn-logout" aria-label="Sign out">
        <%- icons.logOut.replace('<svg ', '<svg class="nav-icon" aria-hidden="true" ') %>
        <span class="nav-label">Sign Out</span>
      </button>
    </div>
  </div>
</aside>
