<div class="set-password-page" id="main-content">
  <div class="set-password-container">
    <div class="set-password-card">
      <div class="set-password-header">
        <a href="/" class="set-password-logo">
          <img src="/images/avatar.svg" alt="No Bhad Codes" class="set-password-logo-img" />
        </a>
        <h1>Reset Password</h1>
        <p class="set-password-subtitle">
          Enter your email address and we'll send you a link to reset your password.
        </p>
      </div>

      <!-- Success State -->
      <div id="success-state" class="set-password-success" style="display: none">
        <div class="success-icon">&#10003;</div>
        <h2>Check Your Email</h2>
        <p>
          If an account exists for <span id="success-email"></span>, you will receive an email
          with instructions to reset your password.
        </p>
        <a href="/#/portal" class="btn btn-filled">Back to Login</a>
      </div>

      <!-- Forgot Password Form -->
      <form id="forgot-password-form" class="set-password-form">
        <div class="form-field">
          <label for="email" class="field-label">Email Address</label>
          <input
            type="email"
            id="email"
            name="email"
            required
            class="form-input"
            placeholder="Enter your email address"
            autocomplete="email"
          />
        </div>

        <div id="form-error" class="form-error" style="display: none"></div>

        <button type="submit" class="btn btn-filled btn-full" id="submit-btn">
          Send Reset Link
        </button>
      </form>

      <div class="set-password-footer">
        <a href="/#/portal" class="auth-link">Back to Login</a>
      </div>
    </div>
  </div>
</div>
