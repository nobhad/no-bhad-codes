<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <meta name="robots" content="noindex, nofollow" />
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <script type="module" src="/src/portal.ts"></script>
</head>
<body data-page="set-password">
  <!-- This page is handled by the existing client/set-password.html -->
  <!-- Redirect to static HTML for now -->
  <script>
    // The static HTML handles this - redirect if accessed via EJS route
    if (window.location.pathname.startsWith('/client/set-password')) {
      const token = window.location.pathname.split('/').pop();
      if (token && token !== 'set-password') {
        window.location.href = '/client/set-password.html?token=' + token;
      }
    }
  </script>
</body>
</html>
