{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/site.webmanifest",
      "headers": [
        { "key": "Content-Type", "value": "application/manifest+json" },
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    },
    {
      "source": "/data/(.*).json",
      "headers": [
        { "key": "Content-Type", "value": "application/json" },
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [{ "key": "X-Content-Type-Options", "value": "nosniff" }]
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://no-bhad-codes-production.up.railway.app/api/:path*"
    },
    {
      "source": "/set-password/:path*",
      "destination": "https://no-bhad-codes-production.up.railway.app/set-password"
    },
    {
      "source": "/forgot-password/:path*",
      "destination": "https://no-bhad-codes-production.up.railway.app/forgot-password"
    },
    {
      "source": "/reset-password/:path*",
      "destination": "https://no-bhad-codes-production.up.railway.app/reset-password"
    },
    {
      "source": "/intake/:path*",
      "destination": "https://no-bhad-codes-production.up.railway.app/intake"
    },
    {
      "source": "/dashboard/:path*",
      "destination": "https://no-bhad-codes-production.up.railway.app/dashboard"
    },
    {
      "source": "/portal/:path*",
      "destination": "https://no-bhad-codes-production.up.railway.app/portal"
    },
    {
      "source": "/client/:path*",
      "destination": "https://no-bhad-codes-production.up.railway.app/client/:path*"
    },
    {
      "source": "/admin/:path*",
      "destination": "https://no-bhad-codes-production.up.railway.app/admin/:path*"
    }
  ]
}
