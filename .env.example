# ============================================================
# APPLICATION SETTINGS
# ============================================================

# Application environment (REQUIRED)
# Valid values: development, production, test
NODE_ENV=development

# Server port (REQUIRED, default: 4001)
PORT=4001

# Frontend URL (REQUIRED, default: http://localhost:4000)
# Must be a valid URL
FRONTEND_URL=http://localhost:4000

# API base URL (optional, default: http://localhost:4001)
# Auto-derived from PORT in development if not set
# Must be a valid URL
API_BASE_URL=http://localhost:4001

# ============================================================
# DATABASE (SQLite)
# ============================================================

# Path to SQLite database file (REQUIRED, default: ./data/client_portal.db)
DATABASE_PATH=./data/client_portal.db

# Path for database backups (optional, default: ./data/backups)
DATABASE_BACKUP_PATH=./data/backups

# Enable WAL mode for better concurrent reads (optional, default: true)
DATABASE_ENABLE_WAL=true

# Busy timeout in milliseconds (optional, default: 5000)
DATABASE_BUSY_TIMEOUT=5000

# ============================================================
# AUTHENTICATION
# ============================================================

# JWT signing secret (REQUIRED, min 32 characters)
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Auto-generated in development if not set or contains "change-this"
JWT_SECRET=change-this-to-a-secure-random-string-at-least-32-chars

# JWT token expiration (optional, default: 7d)
JWT_EXPIRES_IN=7d

# Refresh token signing secret (optional, min 32 characters)
# Auto-generated in development if not set
REFRESH_TOKEN_SECRET=change-this-to-another-secure-random-string-32-chars

# Refresh token expiration (optional, default: 30d)
REFRESH_TOKEN_EXPIRES_IN=30d

# Bcrypt hashing rounds (optional, default: 10, min: 8, max: 15)
BCRYPT_ROUNDS=10

# Session secret (optional, min 32 characters)
# Auto-generated in development if not set
SESSION_SECRET=change-this-to-yet-another-secure-random-string-32ch

# ============================================================
# ADMIN ACCOUNT
# ============================================================

# Admin login email (REQUIRED, must be valid email)
ADMIN_EMAIL=admin@example.com

# Admin login password (REQUIRED, min 8 characters)
ADMIN_PASSWORD=change-this-password

# ============================================================
# BUSINESS INFO (for invoices, PDFs, emails)
# ============================================================

# Business name (REQUIRED)
BUSINESS_NAME=Your Business Name

# Business owner name (optional, falls back to BUSINESS_CONTACT)
BUSINESS_OWNER=Your Name

# Business contact name (optional)
BUSINESS_CONTACT=Your Name

# Business tagline (optional)
BUSINESS_TAGLINE=Your tagline here

# Business email (REQUIRED, must be valid email)
BUSINESS_EMAIL=hello@yourbusiness.com

# Business website URL (optional)
BUSINESS_WEBSITE=https://yourbusiness.com

# Venmo handle for payments (optional)
VENMO_HANDLE=@YourVenmoHandle

# Zelle email for payments (optional, must be valid email)
ZELLE_EMAIL=zelle@yourbusiness.com

# PayPal email for payments (optional, must be valid email)
PAYPAL_EMAIL=paypal@yourbusiness.com

# ============================================================
# EMAIL (SMTP)
# ============================================================

# Enable email sending (optional, default: false)
# When true, SMTP_HOST, SMTP_USER, SMTP_PASS, and FROM_EMAIL become required
EMAIL_ENABLED=false

# SMTP server hostname (required if EMAIL_ENABLED=true)
SMTP_HOST=smtp.example.com

# SMTP server port (optional, default: 587)
SMTP_PORT=587

# Use TLS/SSL for SMTP (optional, default: false)
SMTP_SECURE=false

# SMTP login email (required if EMAIL_ENABLED=true, must be valid email)
SMTP_USER=smtp-user@example.com

# SMTP login password (required if EMAIL_ENABLED=true)
SMTP_PASS=your-smtp-password

# From address for outgoing emails (required if EMAIL_ENABLED=true, must be valid email)
FROM_EMAIL=noreply@yourbusiness.com

# Email address for admin notifications (optional, must be valid email)
ADMIN_NOTIFICATION_EMAIL=admin@yourbusiness.com

# ============================================================
# FILE UPLOADS
# ============================================================

# Maximum upload file size in bytes (optional, default: 10485760 = 10MB)
MAX_FILE_SIZE=10485760

# Comma-separated allowed file extensions (optional)
# Default: jpeg,jpg,png,pdf,doc,docx,txt,zip,rar
ALLOWED_FILE_TYPES=jpeg,jpg,png,pdf,doc,docx,txt,zip,rar

# Upload directory path (optional, default: ./uploads)
UPLOAD_DIR=./uploads

# Temporary file directory (optional, default: ./temp)
TEMP_DIR=./temp

# ============================================================
# RATE LIMITING
# ============================================================

# Rate limit window in milliseconds (optional, default: 900000 = 15 minutes)
RATE_LIMIT_WINDOW_MS=900000

# Max requests per window (optional, default: 100)
RATE_LIMIT_MAX_REQUESTS=100

# Max login attempts per window (optional, default: 5)
RATE_LIMIT_LOGIN_MAX=5

# Max contact form submissions per window (optional, default: 3)
RATE_LIMIT_CONTACT_MAX=3

# ============================================================
# FEATURE FLAGS
# ============================================================

# Allow new user registration (optional, default: true)
ENABLE_REGISTRATION=true

# Allow password reset flow (optional, default: true)
ENABLE_PASSWORD_RESET=true

# Require email verification on signup (optional, default: false)
ENABLE_EMAIL_VERIFICATION=false

# Enable two-factor authentication (optional, default: false)
ENABLE_2FA=false

# Enable API documentation endpoint (optional, default: true)
ENABLE_API_DOCS=true

# Enable maintenance mode (optional, default: false)
MAINTENANCE_MODE=false

# ============================================================
# LOGGING
# ============================================================

# Log level (optional, default: info)
# Valid values: error, warn, info, debug
LOG_LEVEL=info

# Log output format (optional, default: text)
# Valid values: json, text
LOG_FORMAT=text

# Path to application log file (optional, default: ./logs/app.log)
LOG_FILE=./logs/app.log

# Max log file size before rotation (optional, default: 10m)
LOG_MAX_SIZE=10m

# Max log file retention (optional, default: 14d)
LOG_MAX_FILES=14d

# Path to error-only log file (optional, default: ./logs/error.log)
LOG_ERROR_FILE=./logs/error.log

# ============================================================
# CORS
# ============================================================

# Allowed CORS origin (optional, default: http://localhost:3000)
CORS_ORIGIN=http://localhost:3000

# Allow credentials in CORS requests (optional, default: true)
CORS_CREDENTIALS=true

# Allowed HTTP methods (optional, default: GET,POST,PUT,DELETE,OPTIONS)
CORS_METHODS=GET,POST,PUT,DELETE,OPTIONS

# Allowed request headers (optional)
# Default: Content-Type,Authorization,X-Requested-With
CORS_HEADERS=Content-Type,Authorization,X-Requested-With

# ============================================================
# DEVELOPMENT OPTIONS
# ============================================================

# Auto-login as admin in development (optional, default: false)
DEV_AUTO_LOGIN=false

# Use mock data instead of real database (optional, default: false)
DEV_MOCK_DATA=false

# Enable verbose debug logging (optional, default: true)
DEV_VERBOSE_LOGGING=true

# Enable hot module reload (optional, default: true)
DEV_HOT_RELOAD=true

# ============================================================
# PRODUCTION OPTIONS
# ============================================================

# Force HTTPS redirects (optional, default: false)
FORCE_SSL=false

# Trust reverse proxy headers (optional, default: false)
TRUST_PROXY=false

# Enable Helmet security headers (optional, default: true)
HELMET_ENABLED=true

# Number of cluster workers (optional, default: auto)
# Use "auto" for CPU count or a specific number
CLUSTER_WORKERS=auto

# ============================================================
# OPENTELEMETRY / OBSERVABILITY
# ============================================================

# Enable OpenTelemetry tracing (optional, default: true)
OTEL_ENABLED=true

# Service name for traces (optional, default: client-portal)
OTEL_SERVICE_NAME=client-portal

# OTLP exporter endpoint (optional, no default)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# Enable OTEL debug logging (optional, default: false)
OTEL_DEBUG=false

# ============================================================
# URL OVERRIDES (used by getBaseUrl/getAdminUrl/getPortalUrl)
# ============================================================

# Public-facing website URL (optional, checked before FRONTEND_URL)
# WEBSITE_URL=https://yourbusiness.com

# Alias for WEBSITE_URL (optional)
# BASE_URL=https://yourbusiness.com

# Admin panel URL override (optional, derived from base URL + /admin)
# ADMIN_URL=https://yourbusiness.com/admin

# Client portal URL override (optional, derived from base URL + /client/portal)
# CLIENT_PORTAL_URL=https://yourbusiness.com/client/portal

# ============================================================
# GOOGLE CALENDAR INTEGRATION (optional)
# ============================================================

# Google Cloud OAuth2 client ID (required for Google Calendar sync)
# Create at: https://console.cloud.google.com/apis/credentials
# GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Google Cloud OAuth2 client secret (required for Google Calendar sync)
# GOOGLE_CLIENT_SECRET=your-client-secret

# OAuth2 redirect URI (required for Google Calendar sync)
# Must match the authorized redirect URI in Google Cloud Console
# For SPA flow: frontend URL that captures the code and POSTs to /api/integrations/calendar/callback
# GOOGLE_REDIRECT_URI=http://localhost:4001/admin#/integrations/calendar/callback

# ============================================================
# STRIPE INTEGRATION (optional)
# ============================================================

# Stripe secret key (required for Stripe payment integration)
# STRIPE_SECRET_KEY=sk_test_...

# Stripe webhook secret (required for Stripe webhook verification)
# STRIPE_WEBHOOK_SECRET=whsec_...
