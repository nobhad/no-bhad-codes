<section class="terminal-intake-container">
    <!-- Onboarding wizard rendered by React -->
</section>

<script type="module">
    import { mountOnboardingWizard } from '/src/react/features/portal/onboarding/mount.tsx';

    document.addEventListener('DOMContentLoaded', () => {
        const container = document.querySelector('.terminal-intake-container');
        if (container) {
            try {
                mountOnboardingWizard(container);
            } catch (error) {
                console.error('[Intake] Failed to mount onboarding wizard:', error);
                container.innerHTML = `
                    <div class="module-error-state">
                        <h2>Unable to load intake form</h2>
                        <p>Please try refreshing the page or contact nobhaduri@gmail.com</p>
                    </div>
                `;
            }
        }
    });
</script>
